# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# In Vercel: Project → Settings → Environment Variables

# -----------------------------------------------------------------------------
# ePass session (required in production)
# Signs the HttpOnly epass_session cookie after OTP login.
# Used by /api/epass/verify-otp and /api/epass/verify-session.
# Generate: openssl rand -base64 32
# Do not reuse CRON_SECRET or SUPABASE_SERVICE_ROLE_KEY.
EPASS_SESSION_SECRET=

# -----------------------------------------------------------------------------
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Site
NEXT_PUBLIC_SITE_URL=https://savronmn.com
NEXT_PUBLIC_APP_URL=

# Google Analytics 4 (optional — defaults to G-HL5DCE0PK8 when unset)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-HL5DCE0PK8

# -----------------------------------------------------------------------------
# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@savronmn.com

# Outreach prospecting (Apify — admin /admin/outreach)
APIFY_API_TOKEN=
# Google Maps discovery
APIFY_BARBER_ACTOR_ID=compass~crawler-google-places
# Website text for prices & experience
APIFY_WEBSITE_ACTOR_ID=apify~website-content-crawler
# Google Maps reviews for reputation
APIFY_REVIEWS_ACTOR_ID=compass~google-maps-reviews-scraper
# Instagram bio emails
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-profile-scraper
APIFY_MAX_PLACES_PER_SEARCH=20
# Enrichment limits (raise for larger metro scans)
APIFY_WEBSITE_ENRICH_LIMIT=100
APIFY_REVIEWS_ENRICH_LIMIT=50
APIFY_INSTAGRAM_ENRICH_LIMIT=100

# Generate: openssl rand -base64 32
BOOKING_CANCEL_SECRET=

# -----------------------------------------------------------------------------
# Google Wallet (loyalty pass — Add to Google Wallet button in membership emails)
# Issuer ID + class ID from https://pay.google.com/business/console
# GOOGLE_WALLET_CLASS_ID must be {ISSUER_ID}.{your_class_suffix}
# Service account JSON: client_email + private_key from Google Cloud Console
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
# Optional — defaults to {NEXT_PUBLIC_SITE_URL}/icon.png (dark SAVRON mark)
GOOGLE_WALLET_LOGO_URL=

# -----------------------------------------------------------------------------
# Apple Wallet (pkpass + live pass updates via PassKit web service)
WALLET_PRIVATE_KEY=
WALLET_WWDR_CERT=
WALLET_PASSPHRASE=
PASS_TYPE_ID=
TEAM_ID=
APNS_USE_SANDBOX=false

# -----------------------------------------------------------------------------
# Cron (calendar renew + decline sweep)
CRON_SECRET=

# -----------------------------------------------------------------------------
# Google Calendar (barber + shop OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Google Calendar organizer for booking invites (OAuth account — RSVP / decline detection).
# Connect once via /api/calendar/connect-shop while logged into this Google account.
# OAuth tokens saved in Supabase system_config take precedence over this env var.
SHOP_CALENDAR_EMAIL=savronmn@gmail.com
# SAVRON shop calendar (group calendar — public ICS URL in Google Calendar settings).
SAVRON_GOOGLE_CALENDAR_ID=647974e05fc3f7623a296d4bf0a07a875fbabbf1c93155fc80f16000841ba73b@group.calendar.google.com
SAVRON_GOOGLE_CALENDAR_TOKENS=
